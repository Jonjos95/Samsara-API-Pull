# =========================
# PAGINATED FETCH
# =========================
def fetch_all(url: str, params: Dict[str, Any], label: str) -> List[Dict[str, Any]]:
    out: List[Dict[str, Any]] = []
    page = 0
    seen_cursors = set()
    while True:
        page += 1
        if page > MAX_PAGES_SAFEGUARD:
            raise RuntimeError(f"{label}: exceeded {MAX_PAGES_SAFEGUARD} pages; aborting.")
        pr = {k: v for k, v in params.items()
              if k not in ("limit", "after", "startingAfter", "cursor", "pageToken", "nextToken")}
        log(f"GET {label} page {page} params={pr}")
        r = requests.get(url, headers=auth_headers(), params=params, timeout=REQUEST_TIMEOUT)
        if r.status_code == 401:
            raise PermissionError(f"401 {label}: {r.text[:200]}")
        r.raise_for_status()
        data = r.json()

        items = None
        for k in ("data", "items", "vehicles", "results"):
            if isinstance(data, dict) and isinstance(data.get(k), list):
                items = data[k]; break
        if items is None:
            items = data if isinstance(data, list) else []

        if not items:
            log(f"{label}: +0 (done)")
            break

        out.extend(items)
        log(f"{label}: +{len(items)} (total {len(out)})")

        pag = data.get("pagination") or data.get("page") or {}
        next_cursor = None
        token_name = None
        has_more = False
        if isinstance(pag, dict):
            has_more = bool(pag.get("hasNextPage") or pag.get("hasMore") or pag.get("more"))
            if pag.get("nextPageToken"):
                next_cursor = pag["nextPageToken"]; token_name = "pageToken"
            elif pag.get("endCursor") or pag.get("nextCursor") or pag.get("cursor"):
                next_cursor = pag.get("endCursor") or pag.get("nextCursor") or pag.get("cursor")
                token_name = "after"
        if not next_cursor and isinstance(data, dict) and data.get("nextToken"):
            next_cursor = data["nextToken"]; token_name = "nextToken"; has_more = bool(next_cursor)

        if not has_more or not next_cursor:
            break

        key = f"{token_name}:{next_cursor}"
        if key in seen_cursors:
            log(f"{label}: cursor repeated; stopping.")
            break
        seen_cursors.add(key)

        for k in ("after", "startingAfter", "pageToken", "nextToken", "cursor"):
            if k in params and k != token_name:
                params.pop(k, None)
        params[token_name] = next_cursor
        time.sleep(PAGE_PAUSE_SEC)
    return out

# =========================
# SAFE GETTERS
# =========================
def safe_get(d: Any, *path, default=None):
    cur = d
    for p in path:
        if not isinstance(cur, dict) or p not in cur:
            return default
        cur = cur[p]
    return cur

def first_of(d: Dict[str, Any], candidates: List[Tuple[str, ...]], default=None):
    for path in candidates:
        v = safe_get(d, *path, default=None)
        if v is not None:
            return v
    return default

