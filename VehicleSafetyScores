def fetch_tags_map() -> Dict[str, Dict[str, Any]]:
    endpoints = ["https://api.samsara.com/fleet/tags", "https://api.samsara.com/tags"]
    last_err = None
    for url in endpoints:
        try:
            tags: List[Dict[str, Any]] = fetch_all(url, {"limit": 500}, "tags")
            m: Dict[str, Dict[str, Any]] = {}
            for t in tags:
                tid = str(t.get("id") or t.get("tagId") or "")
                if not tid:
                    continue
                m[tid] = {"name": t.get("name", ""), "parents": t.get("parentTagIds") or t.get("parentIds") or []}
            if m:
                return m
        except Exception as e:
            last_err = e
            continue
    log(f"⚠️ Could not fetch Tags; Tag Paths will be blank. ({last_err})")
    return {}

def _build_path(tag_id: str, tags_map: Dict[str, Dict[str, Any]], cache: Dict[str, str]) -> str:
    if tag_id in cache:
        return cache[tag_id]
    t = tags_map.get(tag_id)
    if not t:
        cache[tag_id] = ""
        return ""
    parents = t.get("parents") or []
    parent_paths = []
    for pid in parents:
        p = _build_path(str(pid), tags_map, cache)
        if p:
            parent_paths.append(p)
    base = " / ".join(pp for pp in parent_paths if pp)
    out = (base + " / " + t["name"]) if base else t["name"]
    cache[tag_id] = out
    return out

def tag_names_and_paths(tag_objs_or_names: Any, tags_map: Dict[str, Dict[str, Any]]) -> Tuple[str, str]:
    names: List[str] = []
    paths: List[str] = []
    cache: Dict[str, str] = {}
    seen_names = set()
    if isinstance(tag_objs_or_names, list):
        for t in tag_objs_or_names:
            if isinstance(t, str):
                nm = t.strip()
                if nm and nm not in seen_names:
                    names.append(nm); seen_names.add(nm)
            elif isinstance(t, dict):
                tid = None; nm = None
                if isinstance(t.get("tag"), dict):
                    tid = t["tag"].get("id"); nm = t["tag"].get("name")
                tid = tid or t.get("id")
                nm = nm or t.get("name")
                if nm and nm not in seen_names:
                    names.append(nm.strip()); seen_names.add(nm.strip())
                if tid and tags_map:
                    p = _build_path(str(tid), tags_map, cache)
                    if p:
                        paths.append(p)
    return ", ".join(names), " / ".join(paths) if paths else ""

