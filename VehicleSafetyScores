def is_vehicle_inactive(v: Dict[str, Any]) -> bool:
    if v.get("isDeactivated") is True: return True
    if v.get("deactivated")   is True: return True
    if v.get("active")        is False: return True
    if v.get("isArchived")    is True: return True
    if v.get("archived")      is True: return True
    for k in ("status", "vehicleStatus", "lifecycleStatus"):
        val = str(v.get(k, "")).strip().lower()
        if val in {"archived","inactive","deactivated","retired","disposed"}:
            return True
    tags = v.get("tags") or v.get("tagIds") or []
    tag_names = []
    if isinstance(tags, list):
        for t in tags:
            if isinstance(t, str):
                tag_names.append(t.lower())
            elif isinstance(t, dict):
                nm = t.get("name") or safe_get(t, "tag", "name", default="")
                if nm:
                    tag_names.append(nm.lower())
    if any(any(h in tn for h in INACTIVE_TAG_HINTS) for tn in tag_names):
        return True
    return False

def fetch_all_vehicles() -> List[Dict[str, Any]]:
    endpoints = [
        ("https://api.samsara.com/fleet/vehicles", {"limit": 500, "includeDeactivated": "false"}),
        ("https://api.samsara.com/v1/fleet/vehicles", {"limit": 500})
    ]
    for url, params in endpoints:
        try:
            return fetch_all(url, params, "vehicles")
        except Exception:
            continue
    return []

