def _vehicle_score_request(session: requests.Session, vehicle_id: str, start_ms: int, end_ms: int) -> Dict[str, Any]:
    url = f"https://api.samsara.com/v1/fleet/vehicles/{vehicle_id}/safety/score"
    params = {"startMs": start_ms, "endMs": end_ms}
    for attempt in range(1, MAX_RETRIES + 1):
        try:
            r = session.get(url, params=params, timeout=REQUEST_TIMEOUT)
            if r.status_code == 404:
                return {}
            if r.status_code in (429, 500, 502, 503, 504):
                sleep_s = BACKOFF_BASE * (2 ** (attempt - 1)) + random.uniform(0, 0.25)
                time.sleep(sleep_s); continue
            r.raise_for_status()
            return r.json() if r.text else {}
        except requests.RequestException:
            sleep_s = BACKOFF_BASE * (2 ** (attempt - 1)) + random.uniform(0, 0.25)
            time.sleep(sleep_s)
    return {}

def fetch_vehicle_scores_concurrent(vehicles: List[Dict[str, Any]], start_ms: int, end_ms: int) -> Dict[str, Dict[str, Any]]:
    results: Dict[str, Dict[str, Any]] = {}
    session = requests.Session()
    session.headers.update(auth_headers())

    def worker(v: Dict[str, Any]) -> Tuple[str, Dict[str, Any]]:
        vid = str(v.get("id") or v.get("vehicleId") or v.get("externalIds", {}).get("samsara.vehicleId", ""))
        if not vid:
            return "", {}
        if is_vehicle_inactive(v):
            return vid, {}
        data = _vehicle_score_request(session, vid, start_ms, end_ms)
        return vid, data

    with ThreadPoolExecutor(max_workers=MAX_WORKERS) as ex:
        futs = [ex.submit(worker, v) for v in vehicles]
        for i, fut in enumerate(as_completed(futs), 1):
            vid, data = fut.result()
            if vid:
                results[vid] = data
            if i % 100 == 0 or i == len(futs):
                log(f"Scores fetched: {i}/{len(futs)}")
    session.close()
    return results

# =========================
# NORMALIZATION
# =========================
def norm_score_block(s: Dict[str, Any]) -> Dict[str, Any]:
    out: Dict[str, Any] = {}
    def first(d: Dict[str, Any], *names, default=None):
        for n in names:
            if n in d and d[n] is not None:
                return d[n]
        return default

    out["safetyScore"] = first(s, "safetyScore", "score")

    # driving time/distance – support multiple shapes
    out["driveTimeMs"]    = first(s, "driveTimeMs", "drivingTimeMs", "driveDurationMs", "totalTimeDrivenMs", default=0)
    out["distanceMeters"] = first(s, "distanceMeters", "drivingDistanceMeters", "distance", "totalDistanceDrivenMeters", default=0)

    # overspeed – either dict breakdown OR single aggregate; capture total in either case
    over = first(s, "timeOverSpeedLimitMs", "overSpeedLimitMs", default=None)
    if isinstance(over, dict):
        out["overSpeedLightMs"]    = first(over, "light", default=0) or 0
        out["overSpeedModerateMs"] = first(over, "moderate", default=0) or 0
        out["overSpeedHeavyMs"]    = first(over, "heavy", default=0) or 0
        out["overSpeedSevereMs"]   = first(over, "severe", default=0) or 0
        out["overSpeedTotalMs"]    = (out["overSpeedLightMs"] + out["overSpeedModerateMs"] +
                                      out["overSpeedHeavyMs"] + out["overSpeedSevereMs"])
    else:
        out["overSpeedLightMs"]    = first(s, "timeOverSpeedLimitLightMs",  default=0) or 0
        out["overSpeedModerateMs"] = first(s, "timeOverSpeedLimitModerateMs", default=0) or 0
        out["overSpeedHeavyMs"]    = first(s, "timeOverSpeedLimitHeavyMs",  default=0) or 0
        out["overSpeedSevereMs"]   = first(s, "timeOverSpeedLimitSevereMs", default=0) or 0
        # NEW: capture aggregate when API only provides total
        out["overSpeedTotalMs"]    = int(over or 0)

    out["timeOverMaxSpeedMs"] = first(s, "timeOverMaxSpeedMs", "overMaxSpeedMs", default=0) or 0
    out["maxSpeedMph"]        = first(s, "maxSpeedMph", "maxSpeed", default=None)
    out["maxSpeedAtMs"]       = first(s, "maxSpeedAtMs", "maxSpeedAt", "maxSpeedTimestampMs", default=None)

    sp = first(s, "speedingEvents", "speedingEventCounts", default={}) or {}
    out["lightSpeedCount"]    = first(sp, "light", "lightCount", default=0) or 0
    out["moderateSpeedCount"] = first(sp, "moderate", "moderateCount", default=0) or 0
    out["heavySpeedCount"]    = first(sp, "heavy", "heavyCount", default=0) or 0
    out["severeSpeedCount"]   = first(sp, "severe", "severeCount", default=0) or 0
    out["maxSpeedCount"]      = first(sp, "max", "maxCount", "overMax", default=0) or 0

    out["speedingManualCount"] = first(s, "speedingManualCount", "manualSpeedingCount", default=0) or 0

    def pick(*names):
        for n in names:
            if n in s and s[n] is not None:
                return s[n]
        return 0

    out.update({
        "crashCount": pick("crashCount", "crashes"),
        "followingDistanceCount": pick("followingDistanceCount", "followingDistance"),
        "following02Manual": pick("followingOf0To2sManualCount", "following02Manual"),
        "following24Manual": pick("followingOf2To4sManualCount", "following24Manual"),
        "lateResponseManual": pick("lateResponseManualCount", "lateResponseManual"),
        "defensiveDrivingManual": pick("defensiveDrivingManualCount", "defensiveDrivingManual"),
        "nearCollisionManual": pick("nearCollisionManualCount", "nearCollisionManual"),
        "harshAccel": pick("harshAccelCount", "harshAccelerationCount"),
        "harshBrake": pick("harshBrakeCount", "harshBrakingCount"),
        "harshTurn": pick("harshTurnCount", "harshTurningCount"),
        "mobileUsage": pick("mobileUsageCount", "mobilePhoneUsageCount"),
        "inattentive": pick("inattentiveDrivingCount", "distractedDrivingCount"),
        "drowsy": pick("drowsyCount", "drowsyDrivingCount"),
        "rollingStop": pick("rollingStopCount"),
        "didNotYieldManual": pick("didNotYieldManualCount"),
        "ranRedLightManual": pick("ranRedLightManualCount"),
        "laneDepartureManual": pick("laneDepartureManualCount"),
        "obstructedCameraAuto": pick("obstructedCameraAutoCount"),
        "obstructedCameraManual": pick("obstructedCameraManualCount"),
        "eatingDrinkingManual": pick("eatingDrinkingManualCount"),
        "smokingManual": pick("smokingManualCount"),
        "noSeatBelt": pick("noSeatBeltCount", "noSeatbeltCount"),
        "forwardCollisionWarning": pick("forwardCollisionWarningCount", "fcwCount"),
    })

    behavior_fields = [
        "crashCount","followingDistanceCount","following02Manual","following24Manual",
        "lateResponseManual","defensiveDrivingManual","nearCollisionManual",
        "harshAccel","harshBrake","harshTurn","mobileUsage","inattentive","drowsy",
        "rollingStop","didNotYieldManual","ranRedLightManual","laneDepartureManual",
        "obstructedCameraAuto","obstructedCameraManual","eatingDrinkingManual",
        "smokingManual","noSeatBelt","forwardCollisionWarning",
        "lightSpeedCount","moderateSpeedCount","heavySpeedCount","severeSpeedCount","maxSpeedCount",
    ]
    out["totalEvents"] = int(sum(int(out.get(k) or 0) for k in behavior_fields))
    out["totalBehaviors"] = out["totalEvents"]
    return out

