            "Rolling Stop": s.get("rollingStop", 0) or 0,
            "Did Not Yield (Manual)": s.get("didNotYieldManual", 0) or 0,
            "Ran Red Light (Manual)": s.get("ranRedLightManual", 0) or 0,
            "Lane Departure (Manual)": s.get("laneDepartureManual", 0) or 0,
            "Obstructed Camera (Automatic)": s.get("obstructedCameraAuto", 0) or 0,
            "Obstructed Camera (Manual)": s.get("obstructedCameraManual", 0) or 0,
            "Eating/Drinking (Manual)": s.get("eatingDrinkingManual", 0) or 0,
            "Smoking (Manual)": s.get("smokingManual", 0) or 0,
            "No Seat Belt": s.get("noSeatBelt", 0) or 0,
            "Forward Collision Warning": s.get("forwardCollisionWarning", 0) or 0,
        }
        rows.append(row)

    # Sort & rank
    def _score(x):
        v = x.get("Safety Score")
        try:
            return float(v) if v is not None else -1
        except Exception:
            return -1
    rows.sort(key=lambda r: (_score(r), hms_to_seconds(r["Drive Time (hh:mm:ss)"])), reverse=True)
    for idx, r in enumerate(rows, start=1):
        r["Rank"] = idx
        r["WE Date"] = we_date

    # Debug: print the top included row’s raw & normalized
    if rows:
        top_vid = rows[0]["Vehicle Id"]
        pp_json("TOP ROW Raw Safety Score JSON (Included)", scores_by_vehicle.get(top_vid, {}))
        pp_json("TOP ROW Normalized Score Block (Included)", norm_score_block(scores_by_vehicle.get(top_vid, {})))

    header = [
