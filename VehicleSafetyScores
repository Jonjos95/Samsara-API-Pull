def main():
    end_ms_raw = utc_now_ms()
    end_ms = align_to_last_sunday(end_ms_raw) if ALIGN_WE_TO_LAST_SUNDAY else end_ms_raw
    start_ms = end_ms - LOOKBACK_DAYS * 24 * 3600 * 1000
    _ = get_api_token()

    we_date = fmt_we_date(end_ms, DISPLAY_TZ)
    log(f"Vehicle safety window: {LOOKBACK_DAYS} days ending {we_date}")

    log("Fetching tags…")
    tags_map = fetch_tags_map()

    log("Fetching vehicles…")
    vehicles_all = fetch_all_vehicles()
    log(f"Vehicles returned: {len(vehicles_all)}")

    vehicles = [v for v in vehicles_all if not is_vehicle_inactive(v)]
    log(f"Active vehicles after filter: {len(vehicles)} (filtered out {len(vehicles_all) - len(vehicles)})")

    vid_to_vehicle: Dict[str, Dict[str, Any]] = {}
    for v in vehicles:
        vid = str(v.get("id") or v.get("vehicleId") or v.get("externalIds", {}).get("samsara.vehicleId", ""))
        if vid:
            vid_to_vehicle[vid] = v

    log("Fetching vehicle scores (concurrent)…")
    scores_by_vehicle = fetch_vehicle_scores_concurrent(vehicles, start_ms, end_ms)

    rows: List[Dict[str, Any]] = []
    for v in vehicles:
        vid = str(v.get("id") or v.get("vehicleId") or "")
        if not vid:
            continue

        vname = v.get("name") or v.get("vehicleName") or v.get("label") or "-"
        make = v.get("make") or v.get("vehicleMake") or ""
        model = v.get("model") or v.get("vehicleModel") or ""
        make_model = f"{make}/{model}".strip("/") if make or model else ""

        tags_val = v.get("tags") or v.get("tagIds") or []
        vehicle_tags, tag_paths = tag_names_and_paths(tags_val, tags_map)

        sraw = scores_by_vehicle.get(vid, {}) or {}
        s = norm_score_block(sraw)

        if SKIP_ZERO_ACTIVITY and (int(s.get("driveTimeMs") or 0) == 0) and (float(s.get("distanceMeters") or 0) == 0):
            continue

        drive_ms = s.get("driveTimeMs") or 0
        def pct(part_ms):
            if not drive_ms or not part_ms:
                return ""
            return round(100.0 * part_ms / drive_ms, 2)

        row = {
            "WE Date": we_date,
            "Vehicle Name": vname,
            "Vehicle Tags": vehicle_tags,
            "Tag Paths": tag_paths,
            "Vehicle Id": str(vid),
            "Make/Model": make_model,
            "Safety Score": s.get("safetyScore"),

            "Drive Time (hh:mm:ss)": fmt_hms(s.get("driveTimeMs")),
            "Total Distance (mi)": fmt_miles(s.get("distanceMeters")),

            "Total Events": s.get("totalEvents", 0),
            "Total Behaviors": s.get("totalBehaviors", 0),

            # NEW: capture aggregate overspeed time if severity breakdown missing
            "Time Over Speed Limit (hh:mm:ss) - Total": fmt_hms(s.get("overSpeedTotalMs")),
            "Percent Over Speed (Total)": pct(s.get("overSpeedTotalMs")),

            "Time Over Speed Limit (hh:mm:ss) - Light": fmt_hms(s.get("overSpeedLightMs")),
            "Time Over Speed Limit (hh:mm:ss) - Moderate": fmt_hms(s.get("overSpeedModerateMs")),
            "Time Over Speed Limit (hh:mm:ss) - Heavy": fmt_hms(s.get("overSpeedHeavyMs")),
            "Time Over Speed Limit (hh:mm:ss) - Severe": fmt_hms(s.get("overSpeedSevereMs")),
            "Time Over Max Speed (hh:mm:ss)": fmt_hms(s.get("timeOverMaxSpeedMs")),
            "Speeding (Manual)": s.get("speedingManualCount", 0) or 0,

            "Percent Light Speeding": pct(s.get("overSpeedLightMs")),
            "Percent Moderate Speeding": pct(s.get("overSpeedModerateMs")),
            "Percent Heavy Speeding": pct(s.get("overSpeedHeavyMs")),
            "Percent Severe Speeding": pct(s.get("overSpeedSevereMs")),
            "Percent Max Speed": pct(s.get("timeOverMaxSpeedMs")),

            "Light Speeding Events Count": s.get("lightSpeedCount", 0) or 0,
            "Moderate Speeding Events Count": s.get("moderateSpeedCount", 0) or 0,
            "Heavy Speeding Events Count": s.get("heavySpeedCount", 0) or 0,
            "Severe Speeding Events Count": s.get("severeSpeedCount", 0) or 0,
            "Max Speed Events Count": s.get("maxSpeedCount", 0) or 0,

            "Max Speed (mph)": s.get("maxSpeedMph") or "",
