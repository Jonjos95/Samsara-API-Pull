# =========================
# TIME HELPERS
# =========================
def _zoneinfo(name: str):
    try:
        from zoneinfo import ZoneInfo
        return ZoneInfo(name)
    except Exception:
        return None

def fmt_hms(ms: Optional[int]) -> str:
    if not ms or ms <= 0:
        return "0:00:00"
    s = int(round(ms / 1000))
    h = s // 3600
    m = (s % 3600) // 60
    sec = s % 60
    return f"{h}:{m:02d}:{sec:02d}"

def hms_to_seconds(hms: str) -> int:
    try:
        h, m, s = hms.split(":")
        return int(h) * 3600 + int(m) * 60 + int(s)
    except Exception:
        return 0

def meters_to_miles(m: Optional[float]) -> float:
    return (m or 0.0) * 0.000621371

def fmt_miles(m: Optional[float]) -> str:
    return f"{meters_to_miles(m):.1f}"

def utc_now_ms() -> int:
    return int(datetime.now(timezone.utc).timestamp() * 1000)

def align_to_last_sunday(end_ms: int) -> int:
    tz = _zoneinfo(DISPLAY_TZ)
    dt = datetime.fromtimestamp(end_ms/1000, tz=timezone.utc).astimezone(tz) if tz else datetime.fromtimestamp(end_ms/1000).astimezone()
    delta_days = (dt.weekday() + 1) % 7
    last_sun = (dt - timedelta(days=delta_days)).replace(hour=23, minute=59, second=59, microsecond=0)
    last_sun_utc = last_sun.astimezone(timezone.utc)
    return int(last_sun_utc.timestamp() * 1000)

def fmt_we_date(end_ms: int, tz_name: str) -> str:
    tz = _zoneinfo(tz_name)
    dt = datetime.fromtimestamp(end_ms / 1000, tz=timezone.utc)
    dt_local = dt.astimezone(tz) if tz else dt.astimezone()
    if os.name == "nt":
        return dt_local.strftime("%#m/%#d/%Y")
    return dt_local.strftime("%-m/%-d/%Y")

def fmt_compact_local(ms: Optional[int], tz_name: str) -> str:
    if not ms:
        return ""
    tz = _zoneinfo(tz_name)
    dt = datetime.fromtimestamp(ms / 1000, tz=timezone.utc)
    dt_local = dt.astimezone(tz) if tz else dt.astimezone()
    fmt = "%b %#d %#I:%M%p %Z" if os.name == "nt" else "%b %-d %-I:%M%p %Z"
    return dt_local.strftime(fmt)

