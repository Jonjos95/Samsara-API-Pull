import os
import requests
import pandas as pd
from datetime import datetime, timedelta
import pytz
import logging
import json
import time
from requests.adapters import HTTPAdapter, Retry

# ---------- CONFIG ----------
OUTPUT_DIR = "trip_exports"
GEOCODE_CACHE_FILE = os.path.join(OUTPUT_DIR, "geocode_cache.json")
OUTPUT_CSV = os.path.join(OUTPUT_DIR, "samsara_trip_data.csv")
API_URL_TRIPS = "https://api.samsara.com/v1/fleet/trips"
API_URL_VEHICLES = "https://api.samsara.com/v1/fleet/vehicles"

REGION_TZ = {
    "South Eastern Region": "America/New_York",
    "Northeastern Region": "America/New_York",
    "Western Region": "America/Denver",
}

# ---------- SETUP ----------
logging.basicConfig(level=logging.INFO, format="%(asctime)s [%(levelname)s] %(message)s")
os.makedirs(OUTPUT_DIR, exist_ok=True)

# ---------- HELPERS ----------
def get_api_token():
    token = os.getenv("SAMSARA_API_TOKEN")
    if not token:
        logging.error("Missing SAMSARA_API_TOKEN environment variable.")
        exit(1)
    return token

def load_geocode_cache():
    if os.path.exists(GEOCODE_CACHE_FILE):
        with open(GEOCODE_CACHE_FILE, "r", encoding="utf-8") as f:
            return json.load(f)
    return {}

def save_geocode_cache(cache):
    with open(GEOCODE_CACHE_FILE, "w", encoding="utf-8") as f:
        json.dump(cache, f)

def valid_coordinates(lat, lon):
    return lat is not None and lon is not None and (-90 <= lat <= 90) and (-180 <= lon <= 180)

def reverse_geocode(lat, lon, cache):
    key = f"{lat},{lon}"
    if key in cache:
        return cache[key]

    if not valid_coordinates(lat, lon):
        logging.warning(f"Invalid coordinates: {lat}, {lon}")
        return "Invalid coordinates"

    try:
        res = requests.get("https://nominatim.openstreetmap.org/reverse", params={
            "lat": lat, "lon": lon, "format": "json", "zoom": 16
        }, headers={"User-Agent": "SamsaraTripExport/1.0"}, timeout=10)
        res.raise_for_status()
        address = res.json().get("display_name", "Unknown address")
        cache[key] = address
        time.sleep(1)
        return address
    except Exception as e:
        logging.warning(f"Reverse geocode failed for {key}: {e}")
        cache[key] = "Reverse geocode failed"
        return "Reverse geocode failed"

def requests_session_with_retries():
    session = requests.Session()
    retries = Retry(total=3, backoff_factor=1, status_forcelist=[429, 500, 502, 503, 504])
    session.mount("https://", HTTPAdapter(max_retries=retries))
    return session

def fetch_all_vehicle_ids(headers):
    vehicle_ids = []
    params = {"limit": 100, "offset": 0}
    session = requests_session_with_retries()

    while True:
        res = session.get(API_URL_VEHICLES, headers=headers, params=params)
        res.raise_for_status()
        data = res.json()

        vehicles = data.get("vehicles", [])
        vehicle_ids.extend([v["id"] for v in vehicles if "id" in v])

        if len(vehicles) < params["limit"]:
            break

        params["offset"] += params["limit"]

    return vehicle_ids

def fetch_trips(start_time, end_time, headers, geocode_cache):
    trips = []
    params = {
        "startMs": int(start_time.timestamp() * 1000),
        "endMs": int(end_time.timestamp() * 1000),
        "limit": 100,
        "offset": 0
    }
    session = requests_session_with_retries()

    while True:
        res = session.get(API_URL_TRIPS, headers=headers, params=params)
        res.raise_for_status()

        data = res.json()
        for trip in data.get("trips", []):
            vehicle_id = trip.get("vehicleId")
            start_ms, end_ms = trip.get("startMs"), trip.get("endMs")

            if not vehicle_id or not start_ms or not end_ms:
                continue

            start_dt = datetime.utcfromtimestamp(start_ms / 1000).replace(tzinfo=pytz.utc)
            end_dt = datetime.utcfromtimestamp(end_ms / 1000).replace(tzinfo=pytz.utc)
            duration_min = round((end_dt - start_dt).total_seconds() / 60, 2)

            region = "Western Region"
            tz = pytz.timezone(REGION_TZ.get(region, "America/Denver"))

            trips.append({
                "Vehicle ID": vehicle_id,
                "Region": region,
                "Trip Duration (min)": duration_min,
                "Local Start Time": start_dt.astimezone(tz).strftime("%m/%d/%Y %I:%M:%S %p %Z"),
                "Local End Time": end_dt.astimezone(tz).strftime("%m/%d/%Y %I:%M:%S %p %Z"),
                "Start Address": reverse_geocode(trip.get('startLocation', {}).get('lat'), trip.get('startLocation', {}).get('lon'), geocode_cache),
                "End Address": reverse_geocode(trip.get('endLocation', {}).get('lat'), trip.get('endLocation', {}).get('lon'), geocode_cache)
            })

        if len(data.get("trips", [])) < params["limit"]:
            break
        params["offset"] += params["limit"]

    return trips

# ---------- MAIN ----------
def main():
    token = get_api_token()
    headers = {"accept": "application/json", "authorization": f"Bearer {token}"}

    vehicle_ids = fetch_all_vehicle_ids(headers)
    logging.info(f"Fetched {len(vehicle_ids)} vehicle IDs.")

    geocode_cache = load_geocode_cache()

    now = datetime.utcnow().replace(tzinfo=pytz.utc)
    start_time = now - timedelta(hours=12)

    trips = fetch_trips(start_time, now, headers, geocode_cache)

    if trips:
        pd.DataFrame(trips).to_csv(OUTPUT_CSV, index=False)
        logging.info(f"Exported {len(trips)} trips to {OUTPUT_CSV}")
        save_geocode_cache(geocode_cache)
    else:
        logging.info("No trips found in the given time window.")

if __name__ == "__main__":
    main()
